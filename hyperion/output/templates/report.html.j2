{# HYPERION Main Report Template — Jinja2 template for the FinalReport.

This is NOT a generic HTML template. It implements the premium report
structure from ARCHITECTURE.md §6.1:

  Cover → TOC → Executive Summary → Sections → Risk → Methodology →
  Appendix → Back Cover

Each section includes:
- Section header (Instrument Serif, 22pt, Terracotta border)
- Body content (JetBrains Mono, 10pt, justified)
- Key findings with confidence and sources
- Charts (full-width, centered, with caption and source)
- Tables (JetBrains Mono, perfect number alignment)
- Section images (40% width, right-aligned, with caption)
- Key insight boxes (Terracotta border, Beige background)

Architecture reference: §6.1 Premium Structure, §6.3 Image Rules,
§7.2 PDF Report Palette, §7.4 Typography
#}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ report.title }}</title>
</head>
<body>

{# ─────────────────────────────────────────────────────────────────────────────
   Table of Contents
   ───────────────────────────────────────────────────────────────────────────── #}
<div class="page-break"></div>
<section id="toc">
    <h1>Table of Contents</h1>
    <ol>
        <li><a href="#executive-summary">Executive Summary</a></li>
        {% for section in report.sections %}
        <li><a href="#section-{{ loop.index }}">{{ loop.index }}. {{ section.title }}</a></li>
        {% endfor %}
        <li><a href="#risk-analysis">Risk Analysis</a></li>
        <li><a href="#methodology">Methodology</a></li>
        <li><a href="#appendix">Appendix</a></li>
    </ol>
</section>

{# ─────────────────────────────────────────────────────────────────────────────
   Executive Summary
   ───────────────────────────────────────────────────────────────────────────── #}
<div class="page-break"></div>
<section id="executive-summary">
    <h1>Executive Summary</h1>

    {% if report.executive_summary and report.executive_summary.key_findings %}
    <h3>Key Findings</h3>
    <ul>
        {% for finding in report.executive_summary.key_findings %}
        <li>{{ finding }}</li>
        {% endfor %}
    </ul>
    {% endif %}

    {% if report.executive_summary and report.executive_summary.recommendations %}
    <h3>Recommendations</h3>
    <ul>
        {% for rec in report.executive_summary.recommendations %}
        <li>{{ rec }}</li>
        {% endfor %}
    </ul>
    {% endif %}

    {% if report.executive_summary and report.executive_summary.key_metrics %}
    <h3>Key Metrics</h3>
    <table>
        <thead>
            <tr><th>Metric</th><th>Value</th></tr>
        </thead>
        <tbody>
            {% for key, value in report.executive_summary.key_metrics.items() %}
            <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</section>

{# ─────────────────────────────────────────────────────────────────────────────
   Report Sections
   ───────────────────────────────────────────────────────────────────────────── #}
{% for section in report.sections %}
<div class="page-break"></div>
<section id="section-{{ loop.index }}">
    <h1>{{ loop.index }}. {{ section.title }}</h1>

    {# Section content (markdown-rendered HTML) #}
    {% if section.content %}
    <div class="section-content">
        {{ section.content | safe }}
    </div>
    {% endif %}

    {# Key findings #}
    {% if section.findings %}
    <h3>Key Findings</h3>
    {% for finding in section.findings %}
    <div class="key-insight">
        {% if finding is mapping %}
            <strong>{{ finding.title }}</strong>
            <p>{{ finding.description }}</p>
            {% if finding.confidence %}
            <p><span class="text-warm-gray">Confidence: {{ finding.confidence }}</span></p>
            {% endif %}
            {% if finding.sources %}
            <p><span class="text-warm-gray">Sources: {{ finding.sources | join(", ") }}</span></p>
            {% endif %}
        {% else %}
            <p>{{ finding }}</p>
        {% endif %}
    </div>
    {% endfor %}
    {% endif %}

    {# Charts #}
    {% if section.charts %}
    {% for chart in section.charts %}
    <figure class="chart-figure no-break">
        {% if chart.image_path %}
        <img src="{{ chart.image_path }}" alt="{{ chart.caption or chart.title }}">
        {% endif %}
        {% if chart.caption or chart.title %}
        <figcaption>
            {{ chart.caption or chart.title }}
            {% if chart.source %}
            <span class="source">Source: {{ chart.source }}</span>
            {% endif %}
        </figcaption>
        {% endif %}
    </figure>
    {% endfor %}
    {% endif %}

    {# Data tables #}
    {% if section.tables %}
    {% for table in section.tables %}
    <table class="{% if table.is_financial %}financial-table{% elif table.is_risk %}risk-table{% endif %}">
        {% if table.headers %}
        <thead>
            <tr>
                {% for header in table.headers %}
                <th>{{ header }}</th>
                {% endfor %}
            </tr>
        </thead>
        {% endif %}
        <tbody>
            {% for row in table.rows %}
            <tr>
                {% for cell in row %}
                <td>{{ cell }}</td>
                {% endfor %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endfor %}
    {% endif %}

    {# Section images — 40% width, right-aligned, with caption #}
    {% if section.images %}
    {% for img in section.images %}
    <figure class="no-break">
        {% if img.local_path or img.image_path %}
        <img src="{{ img.local_path or img.image_path }}" alt="{{ img.caption or img.description }}">
        {% endif %}
        <figcaption>
            {{ img.caption or img.description or "" }}
            {% if img.photographer %}
            <span class="source">Photo: {{ img.photographer }} via Unsplash</span>
            {% endif %}
        </figcaption>
    </figure>
    {% endfor %}
    {% endif %}

</section>
{% endfor %}

{# ─────────────────────────────────────────────────────────────────────────────
   Risk Analysis
   ───────────────────────────────────────────────────────────────────────────── #}
{% if report.risks %}
<div class="page-break"></div>
<section id="risk-analysis">
    <h1>Risk Analysis</h1>

    <table class="risk-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Risk</th>
                <th>Severity</th>
                <th>Probability</th>
                <th>Mitigation</th>
            </tr>
        </thead>
        <tbody>
            {% for risk in report.risks[:10] %}
            <tr>
                <td>{{ loop.index }}</td>
                <td>{{ risk.name or risk.title }}</td>
                <td>{{ risk.severity }}</td>
                <td>{{ risk.probability }}</td>
                <td>{{ risk.mitigation or risk.recommendation }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {% for risk in report.risks[:5] %}
    <div class="risk-indicator">
        <strong>{{ risk.name or risk.title }}</strong>
        <p>{{ risk.description }}</p>
        <p><span class="text-warm-gray">Mitigation: {{ risk.mitigation or risk.recommendation }}</span></p>
    </div>
    {% endfor %}
</section>
{% endif %}

{# ─────────────────────────────────────────────────────────────────────────────
   Methodology — Deep Brown background
   ───────────────────────────────────────────────────────────────────────────── #}
<div class="page-break"></div>
<section id="methodology" class="methodology">
    <h1>Methodology</h1>

    {% if report.methodology and report.methodology.agents_used %}
    <h3>Agents Deployed</h3>
    <ul>
        {% for agent in report.methodology.agents_used %}
        <li>
            {% if agent is mapping %}
                <strong>{{ agent.name }}</strong> — {{ agent.role }}
            {% else %}
                {{ agent }}
            {% endif %}
        </li>
        {% endfor %}
    </ul>
    {% endif %}

    {% if report.methodology and report.methodology.data_sources %}
    <h3>Data Sources</h3>
    <ul>
        {% for source in report.methodology.data_sources %}
        <li>
            {% if source is mapping %}
                {{ source.name }} — <span class="text-warm-gray">{{ source.type }}</span>
            {% else %}
                {{ source }}
            {% endif %}
        </li>
        {% endfor %}
    </ul>
    {% endif %}

    {% if report.methodology and report.methodology.tools_used %}
    <h3>Tools Used</h3>
    <ul>
        {% for tool in report.methodology.tools_used %}
        <li>{{ tool }}</li>
        {% endfor %}
    </ul>
    {% endif %}

    <p><span class="text-warm-gray">Generated by HYPERION on {{ generated_date }}</span></p>
</section>

{# ─────────────────────────────────────────────────────────────────────────────
   Appendix
   ───────────────────────────────────────────────────────────────────────────── #}
{% if report.appendix %}
<div class="page-break"></div>
<section id="appendix">
    <h1>Appendix</h1>

    {% if report.appendix.sources %}
    <h3>Sources</h3>
    <ol>
        {% for source in report.appendix.sources %}
        <li>
            {% if source is mapping %}
                <a href="{{ source.url }}">{{ source.title }}</a>
                — <span class="text-warm-gray">Credibility: {{ source.credibility }}</span>
            {% else %}
                {{ source }}
            {% endif %}
        </li>
        {% endfor %}
    </ol>
    {% endif %}

    {% if report.appendix.glossary %}
    <h3>Glossary</h3>
    <dl>
        {% for term, definition in report.appendix.glossary.items() %}
        <dt><strong>{{ term }}</strong></dt>
        <dd>{{ definition }}</dd>
        {% endfor %}
    </dl>
    {% endif %}
</section>
{% endif %}

{# ─────────────────────────────────────────────────────────────────────────────
   Back Cover
   ───────────────────────────────────────────────────────────────────────────── #}
<div class="page-break"></div>
<div class="back-cover">
    <div class="wordmark">HYPERION</div>
    <div class="tagline">many minds. one reading.</div>
</div>

</body>
</html>
