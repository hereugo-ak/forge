{# HYPERION Cover Page Template — full-bleed image with title overlay.

Architecture reference: §6.3 rule 2 — "Cover image = full-bleed. No text
overlay except the title, subtitle, and wordmark. The cover is a visual
statement."

§7.2 — Cream background, Warm Charcoal text, Terracotta accent.
§7.4 — Instrument Serif for cover title (36pt), JetBrains Mono for metadata.
#}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ cover.title }}</title>
</head>
<body>
    <div class="cover{% if not cover.image_path %} cover--typographic{% endif %}">
        {% if cover.image_path %}
        <img src="{{ cover.image_path }}" alt="{{ cover.title }}" class="cover-image">
        <div class="cover-overlay"></div>
        {% else %}
        <div class="cover-accent-rule"></div>
        {% endif %}

        <div class="cover-content">
            <div class="cover-wordmark">HYPERION</div>
            <h1 class="cover-title">{{ cover.title }}</h1>
            {% if cover.subtitle %}
            <div class="cover-subtitle">{{ cover.subtitle }}</div>
            {% endif %}
            {% if cover.client %}
            <div class="cover-client">Prepared for: {{ cover.client }}</div>
            {% endif %}
            <div class="cover-date">{{ generated_date }}</div>
        </div>
    </div>
</body>
</html>
