# ═══════════════════════════════════════════════════════════════════════════
# HYPERION — Environment Configuration
# All variables use HYPERION_ prefix (not FORGE_)
# Copy this file to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM Provider API Keys ──────────────────────────────────────────────────
# All 5 providers expose OpenAI-compatible APIs
HYPERION_GOOGLE_API_KEY=your_google_ai_studio_key
HYPERION_NVIDIA_API_KEY=your_nvidia_nim_key
HYPERION_CEREBRAS_API_KEY=your_cerebras_key
HYPERION_GROQ_API_KEY=your_groq_key
HYPERION_MISTRAL_API_KEY=your_mistral_key

# ── Provider Base URLs ─────────────────────────────────────────────────────
# OpenAI-compatible endpoints for each provider
HYPERION_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
HYPERION_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
HYPERION_CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
HYPERION_GROQ_BASE_URL=https://api.groq.com/openai/v1
HYPERION_MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ── Data Source API Keys ───────────────────────────────────────────────────
HYPERION_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
HYPERION_FRED_API_KEY=your_fred_key
HYPERION_UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ── Search Infrastructure ──────────────────────────────────────────────────
# SearxNG — self-hosted meta-search, Docker-based
HYPERION_SEARXNG_URL=http://localhost:8888

# Jina — search + reader
HYPERION_JINA_API_KEY=your_jina_key

# Obscura — Rust headless browser for JS-rendered pages
# Path to the obscura binary, or leave empty if in PATH
HYPERION_OBSCURA_PATH=

# ── Second Brain (Obsidian Vault) ──────────────────────────────────────────
# Path to the vault directory (default: ./vault)
HYPERION_VAULT_PATH=./vault

# ── Report Output ──────────────────────────────────────────────────────────
# Where generated PDFs are saved (default: ./reports)
HYPERION_REPORTS_DIR=./reports

# ── Assets ─────────────────────────────────────────────────────────────────
# Where cached images and fonts are stored (default: ./assets)
HYPERION_ASSETS_DIR=./assets

# ── Quality Gate ───────────────────────────────────────────────────────────
# Minimum quality score to approve a report (1-5 scale, default: 4.0)
HYPERION_QUALITY_THRESHOLD=4.0

# Maximum quality gate iterations before escalation (default: 3)
HYPERION_MAX_QUALITY_ITERATIONS=3

# ── Sub-Agent Configuration ────────────────────────────────────────────────
# Timeout for sub-agent research in seconds (default: 300 = 5 min)
HYPERION_SUB_AGENT_TIMEOUT=300

# Maximum sub-agents per specialist per engagement (default: 3)
HYPERION_MAX_SUB_AGENTS=3

# ── Wait Gate ──────────────────────────────────────────────────────────────
# Daily budget reserve percentage per provider (default: 0.20 = 20%)
HYPERION_BUDGET_RESERVE=0.20

# Cooldown period after a 429 in seconds (default: 60)
HYPERION_RATE_LIMIT_COOLDOWN=60

# Circuit breaker threshold — consecutive failures before cooldown (default: 3)
HYPERION_CIRCUIT_BREAKER_THRESHOLD=3

# Circuit breaker cooldown period in seconds (default: 300 = 5 min)
HYPERION_CIRCUIT_BREAKER_COOLDOWN=300

# ── Engagement ─────────────────────────────────────────────────────────────
# Maximum engagement duration in seconds (default: 900 = 15 min)
HYPERION_MAX_ENGAGEMENT_DURATION=900

# ── Logging ────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
HYPERION_LOG_LEVEL=INFO

# ── Development ────────────────────────────────────────────────────────────
# Set to true to enable verbose router/failover logging
HYPERION_DEBUG_ROUTER=false
